# --- Source of photos -------------------------------------------------------
# "mock" (default): sample photos, runs with zero setup.
# "google": real Google Drive folder via a service account.
DRIVE_PROVIDER=mock

# --- Google Drive (only when DRIVE_PROVIDER=google) --------------------------
# 1. Create a service account + JSON key in Google Cloud.
# 2. Share the Drive folder with the service account email (Viewer).
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
DRIVE_FOLDER_ID=1Zv2dSHqLw7D-UPUcCNSmUrY3B410yLER

# --- Theme / scoring ---------------------------------------------------------
THEME=最高の乾杯
# Axis weights — see README-SCORING.md. Used by both the AI judge and the
# dummy scorer. にぎやかさ(人数)主役の配分: 他3軸は各20点、にぎやかさは40点。
# 合計は4軸の配点の和（重みの合計は 1.0）。にぎやかさ点は“実際の人数”だけで
# 細かく決まり、画像ごとに安定した ±5点 の面白さブレが乗る。
# 笑顔・表情（20点）
W_MOOD=0.2
# にぎやかさ（人数）（40点・主役）
W_PEOPLE=0.4
# 構図・遠近感（20点）
W_COMPOSITION=0.2
# 写りの良さ（顔のわかりやすさ・描写）（20点）
W_CLARITY=0.2
# Lowest possible per-axis score (加点方式の底上げ). Keeps every total at/above 20
# while leaving a wide 15〜100 spread.
FLOOR=15

# --- AI judge (Claude vision) ------------------------------------------------
# When ANTHROPIC_API_KEY is set, photos are judged by reading the real pixels
# (人数・笑顔・遠近・写りの良さ + 右手グッド等のポーズ検出). Without a key it
# falls back to the dummy scorer, and the AI judge also falls back per-image on
# any error. Set SCORER=dummy to force the dummy scorer even with a key set.
ANTHROPIC_API_KEY=
SCORER=ai
JUDGE_MODEL=claude-opus-4-8

# --- Scan results → Google Sheet (DB) ----------------------------------------
# スキャン後の結果を、画像idをキーにこのシートへ upsert する。
# 列: A=画像id B=合計スコア C=スキャン済みフラグ D=(空) E=user名 F=画像名。
#
# 【推奨】Apps Script Web App（課金もサービスアカウントも不要）:
#   手順は server/sheets/apps-script.gs を参照。発行されたURLを下に貼る。
SHEET_WEBHOOK_URL=
# 任意の共有シークレット（Apps Script 側の SHEET_TOKEN と一致させる。未使用なら空）
SHEET_WEBHOOK_TOKEN=
#
# 【代替】サービスアカウント方式を使うなら、上の GOOGLE_APPLICATION_CREDENTIALS を設定し、
#   対象シートをサービスアカウントのメールに「編集者」で共有する。
#
# どちらも未設定なら保存は自動的に無効（採点は通常どおり動作）。SHEET_SYNC=off で明示無効化。
SHEET_ID=1WVjDUq_F5NQgXn50KeoURIiC7Jho68QxO1kp84n2jeY
SHEET_SYNC=auto

# --- Timing ------------------------------------------------------------------
POLL_INTERVAL_MS=8000
# mock-only: how often a new sample photo "arrives"
MOCK_ARRIVAL_MS=25000
MOCK_INITIAL=6
