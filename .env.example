# --- Source of photos -------------------------------------------------------
# "mock" (default): sample photos, runs with zero setup.
# "google": real Google Drive folder via a service account.
DRIVE_PROVIDER=mock

# --- Google Drive (only when DRIVE_PROVIDER=google) --------------------------
# 1. Create a service account + JSON key in Google Cloud.
# 2. Share the Drive folder with the service account email (Viewer).
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
DRIVE_FOLDER_ID=1gFfMPwP7fhoWD8IenKLPZPt6PCmibsxw

# --- Theme / scoring ---------------------------------------------------------
THEME=最高の乾杯
# Axis weights — see README-SCORING.md (used by the dummy scorer now;
# same shape feeds the real AI judge later). Defaults sum to 1.0.
# 笑顔・表情
W_MOOD=0.30
# にぎやかさ（人数）
W_PEOPLE=0.25
# 構図・遠近感
W_COMPOSITION=0.25
# 写りの良さ（顔のわかりやすさ・描写）
W_CLARITY=0.20
# Lowest possible per-axis score (加点方式の底上げ). No photo scores below this.
FLOOR=50

# --- Timing ------------------------------------------------------------------
POLL_INTERVAL_MS=8000
# mock-only: how often a new sample photo "arrives"
MOCK_ARRIVAL_MS=25000
MOCK_INITIAL=6
